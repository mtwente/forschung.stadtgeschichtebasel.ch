# Omeka S API Configuration
# Copy this file to .env and fill in your actual credentials

# Omeka S API Base URL
OMEKA_API_URL=https://omeka.unibe.ch/api

# API Authentication Keys
# Get these from: https://omeka.unibe.ch (User Profile → API Keys)
KEY_IDENTITY=your_key_identity_here
KEY_CREDENTIAL=your_key_credential_here

# Collection Item Set ID
# The ID of the collection you want to process
# Can be found in the URL of the collection page
ITEM_SET_ID=10780

# Optional metadata validation
# Write literal URL warnings to a report file for Omeka data cleanup
# VALIDATION_REPORT_PATH=validation_report.txt

# Fail data processing when literal metadata values contain URLs
# FAIL_ON_LITERAL_URLS=false
